# ============================================================
# Neo Eco Cleaning — AI Marketing Dashboard
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Google Gemini (for AI-powered email writing & content generation) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- SMTP (for sending emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=hello@neoecocleaning.co.uk
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=hello@neoecocleaning.co.uk
SENDER_NAME=Neo Eco Cleaning

# --- IMAP (for reply tracking) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=hello@neoecocleaning.co.uk
IMAP_PASSWORD=your_app_password_here

# --- Apollo.io (optional, for lead enrichment) ---
APOLLO_API_KEY=your_apollo_api_key_here

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8001
SECRET_KEY=change-this-to-a-random-string

# --- Email Safety ---
# Max emails per day (for domain warmup, start low)
MAX_EMAILS_PER_DAY=30
# Delay between emails in seconds
EMAIL_DELAY_SECONDS=60
# Set to true for testing (emails logged but not sent)
DRY_RUN=true

# --- Reply Tracking ---
REPLY_SCAN_DAYS=3

# --- Open Tracking ---
TRACKING_BASE_URL=http://127.0.0.1:8001
